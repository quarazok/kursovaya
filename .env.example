# Пароль для SA-пользователя MS SQL Server.
# Требования: минимум 8 символов, заглавная + строчная буквы, цифра, спецсимвол.
# Иначе контейнер БД не стартует.
SA_PASSWORD=YourStrong!Pass123

# Ключ для подписи JWT-токенов. Должен быть длинным (32+ символов).
JWT_KEY=ChangeMe_VeryLongSecretKey_AtLeast32Chars
